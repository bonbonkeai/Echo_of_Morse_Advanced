# Ce fichier est commité dans le repo uniquement pour l'évaluation finale.
# En développement, chaque membre utilise son propre .env local — ne pas modifier ce fichier.

# Database
# Example: postgresql://postgres:password@db:5432/transcendence
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

DATABASE_URL=

# NextAuth
NEXTAUTH_SECRET=
NEXTAUTH_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 42 School OAuth
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=

# WebSocket — URL du serveur ws-server, keep vide. 
NEXT_PUBLIC_WS_URL=

# Shared secret used by web and ws-server for socket tokens and internal status updates.
WS_SHARED_SECRET=

# Concurrent-user test settings
# For make test in docker compose, TEST_BASE_URL is usually https://waf:8443.
TEST_BASE_URL=
TEST_RADIO_ID=
TEST_USER_COUNT=
TEST_PASSWORD=
TEST_TLS_REJECT_UNAUTHORIZED=
